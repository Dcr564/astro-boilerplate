---
const { logo = "MiEmpresa", basePath = "" } = Astro.props;
---

<header class="header">
  <div class="container header-inner">

    <a href={`${basePath}/`} class="logo">{logo}</a>

    <nav class="nav">
      <a href={`${basePath}/`}>Inicio</a>
      <a href={`${basePath}/servicios/`}>Servicios</a>
      <a href={`${basePath}/contacto/`}>Contacto</a>
    </nav>

  </div>
</header>