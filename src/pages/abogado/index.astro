---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import "../../styles/abogado.css";
---

<BaseLayout pageClass="abogado">

<Header logo="Abogado Penal Madrid" basePath="/abogado" />

<main>

<section class="hero">
  <div class="container hero-content">

    <div>
      <h1>Defensa penal inmediata en Madrid</h1>
      <p>Te ayudamos desde el primer momento con total confidencialidad</p>

      <a href="/abogado/contacto/" class="btn">Consulta gratuita</a>

      <p>✔ Disponible 24h · ✔ Respuesta rápida</p>
    </div>

    <img src="/images/abogado.jpg" alt="Abogado profesional" />

  </div>
</section>

<section class="services container">
  <h2>Servicios legales</h2>

  <div class="grid">

    <div class="card">
      <h3>Detenciones</h3>
      <p>Asistencia inmediata en comisaría</p>
    </div>

    <div class="card">
      <h3>Juicios penales</h3>
      <p>Defensa sólida en tribunales</p>
    </div>

    <div class="card">
      <h3>Delitos económicos</h3>
      <p>Casos complejos y estrategia legal</p>
    </div>

    <div class="card">
      <h3>Urgencias 24h</h3>
      <p>Disponible cuando más lo necesitas</p>
    </div>

  </div>
</section>

<section class="cta">
  <h2>Habla con un abogado ahora</h2>
  <a href="/abogado/contacto/" class="btn">Consulta gratuita</a>
</section>

</main>

<Footer />

</BaseLayout>